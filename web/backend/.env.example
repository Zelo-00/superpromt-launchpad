# SuperPromt — конфигурация бэкенда (скопируйте в .env и заполните)

# --- LLM-провайдер для «глубокой» оценки (BYOK, достаточно одного) ---
# Без ключа приложение работает в Fast Mode: детерминированный prescreen + watchdog.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# --- Безопасность ---
# Разрешённые источники CORS (через запятую). Wildcard "*" отключает credentials.
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
# Rate limiting: запросов на окно / длина окна в секундах
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW=60
